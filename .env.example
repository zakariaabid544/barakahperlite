# Barakah Perlite local email configuration
# Copy this file to `.env.local` for local development.
# Never commit `.env.local`; it contains the real OVH mailbox password.
#
# Vercel later:
# Add the same variables in Project Settings -> Environment Variables
# for Preview and Production deployments.

SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@barakahperlite.com
SMTP_PASSWORD=YOUR_OVH_EMAIL_PASSWORD
CONTACT_RECEIVER=info@barakahperlite.com

# Private portal and analytics
# DATABASE_URL must point to a real PostgreSQL database before going online.
# After configuring DATABASE_URL, run:
# npx prisma migrate deploy
# npm run db:seed
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# Private admin sessions and seed-only setup.
# SESSION_SECRET must be a long random secret and must be rotated before production.
# SEED_ADMIN_PASSWORD is used only by the seed script, never by runtime login.
SESSION_SECRET=replace-with-a-random-64-character-secret
NEXT_PUBLIC_SITE_URL=https://barakahperlite.com
SEED_ADMIN_EMAILS=replace-admin@example.com
SEED_ADMIN_PASSWORD=replace-with-a-strong-temporary-seed-password
